# Copy this to .env and fill in your values.

# ---------- Server ----------
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ---------- Database ----------
DATABASE_URL=postgresql://argon:argon_dev_password@localhost:5432/argon

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379

# ---------- S3 ----------
# For local dev with MinIO (included in docker-compose.yml):
#   AWS_REGION=us-east-1
#   AWS_ACCESS_KEY_ID=argon_minio
#   AWS_SECRET_ACCESS_KEY=argon_minio_secret
#   S3_BUCKET=argon-local
#   S3_ENDPOINT=http://localhost:9000
# For real AWS: leave S3_ENDPOINT unset and fill in actual credentials.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET=your-bucket-name
S3_PRESIGN_EXPIRES_SECONDS=900
# S3_ENDPOINT=http://localhost:9000

# ---------- Validation thresholds ----------
MIN_FILE_SIZE_BYTES=51200
MAX_FILE_SIZE_BYTES=26214400
MIN_IMAGE_WIDTH=512
MIN_IMAGE_HEIGHT=512
BLUR_LAPLACIAN_THRESHOLD=100
MIN_FACE_AREA_RATIO=0.05
SIMILARITY_HAMMING_THRESHOLD=5

# ---------- face-api ----------
FACE_API_MODELS_DIR=./models

# ---------- Pipeline ----------
# JPEG quality used by the compress stage (1-100, mozjpeg encoder).
COMPRESS_JPEG_QUALITY=82
# Comma-separated widths in px for thumbnail,web,full variants.
VARIANT_WIDTHS=256,1280,2560
# JPEG quality for the resized variants.
VARIANT_JPEG_QUALITY=85
# Reconciler interval and stuck-threshold (ms). The reconciler re-enqueues
# rows whose pipelineStage hasn't progressed within RECONCILER_STUCK_AFTER_MS.
RECONCILER_INTERVAL_MS=60000
RECONCILER_STUCK_AFTER_MS=300000
