{
  "name": "@argon/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker/index.ts",
    "dev:worker:convert": "tsx watch src/worker/convert/index.ts",
    "dev:worker:compress": "tsx watch src/worker/compress/index.ts",
    "dev:worker:variants": "tsx watch src/worker/variants/index.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker/index.js",
    "start:worker:convert": "node dist/worker/convert/index.js",
    "start:worker:compress": "node dist/worker/compress/index.js",
    "start:worker:variants": "node dist/worker/variants/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "fetch-models": "tsx scripts/fetch-models.ts",
    "test": "bun test --preload ./src/__tests__/setup.ts src/__tests__/**/*.test.ts",
    "test:watch": "bun test --watch --preload ./src/__tests__/setup.ts src/__tests__/**/*.test.ts"
  },
  "dependencies": {
    "@argon/shared": "*",
    "@aws-sdk/client-s3": "^3.658.0",
    "@aws-sdk/s3-request-presigner": "^3.658.0",
    "@prisma/client": "^5.20.0",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@tensorflow/tfjs-node": "^4.22.0",
    "@vladmandic/face-api": "^1.7.14",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "heic-convert": "^2.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "morgan": "^1.10.0",
    "onnxruntime-node": "^1.26.0",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.16.5",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  }
}
